generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model Clientes {
  id            Int    @id @default(autoincrement())
  nome_completo String
  cpf           String  @unique
  email         String  @unique
  cnh           String
}

model veiculo {
  id Int @id @default(autoincrement())
  placa String @unique
  modelo String
  marca String
  ano Int
}